# Database (Prisma / Postgres)
DATABASE_URL=
DIRECT_DATABASE_URL=
PRISMA_DATABASE_URL=
POSTGRES_URL=

JWT_SECRET=
NODE_ENV=development

BLOB_READ_WRITE_TOKEN=
FRONTEND_URL=https://intercambius.com.ar

# =============================================================================
# GOOGLE OAUTH — SON DOS CLIENTES DISTINTOS (no mezclar IDs ni secrets)
# =============================================================================
#
# A) GMAIL SMTP (proyecto polar-fulcrum / cliente 318912...)
#    Envío de emails: MFA, reset password, bienvenida.
#    Requiere: Client ID + Secret + Refresh Token (npm run gmail-oauth-token).
#
# B) GOOGLE SIGN-IN (proyecto composed-arch / cliente 725093...)
#    Login/registro con botón Google en el front.
#    Requiere: solo Client ID en backend (GOOGLE_OAUTH_CLIENT_ID).
#    El secret del JSON de Sign-In NO se usa en este proyecto.
#    En el front: VITE_GOOGLE_CLIENT_ID = mismo valor que GOOGLE_OAUTH_CLIENT_ID.
#    En Google Cloud: orígenes JS autorizados (intercambius.com.ar, localhost:5173).
#
# =============================================================================

# --- A) Correo (Google Workspace: noreply@intercambius.com.ar) ---
SMTP_USER=noreply@intercambius.com.ar
SMTP_FROM="Intercambius" <noreply@intercambius.com.ar>
CONTACT_INBOX_EMAIL=noreply@intercambius.com.ar
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
# GMAIL_OAUTH_REDIRECT_URI=http://127.0.0.1:8787

# --- B) Google Sign-In (mismo Client ID que VITE_GOOGLE_CLIENT_ID del front) ---
GOOGLE_OAUTH_CLIENT_ID=
# Secret del cliente Web 725093... (flujo redirect OAuth; solo backend, nunca en el front)
GOOGLE_OAUTH_CLIENT_SECRET=
# En Google Cloud → URIs de redirección autorizadas, agregar:
#   https://intercambius.com.ar/auth/google/callback
#   http://localhost:5173/auth/google/callback

# LOGO_URL=https://intercambius.com.ar/logo-intercambius.png

ADMIN_EMAIL=admin@intercambius.com.ar
ADMIN_PASSWORD=

API_KEY_DIDIT=
WORKFLOW_DIDIT=
ID_DIDIT=

# Destino opcional para npm run email:test-all
# EMAIL_TEST_TO=tu@email.com

# Google Maps / Geocoding (misma key que el front; restringir por dominio + IP backend)
GOOGLE_MAPS_API_KEY=

# reCAPTCHA v2 (site key en VITE_RECAPTCHA_SITE_KEY del front)
RECAPTCHA_SECRET_KEY=
