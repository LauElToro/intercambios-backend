# Base de datos
DATABASE_URL="postgresql://user:pass@localhost:5432/intercambius"

# URL del frontend (enlaces en correos y CORS: debe coincidir con el origen del navegador, sin barra final)
FRONTEND_URL="http://localhost:8080"
# Orígenes extra permitidos para CORS, separados por coma (ej. www y apex, staging)
# CORS_ORIGINS="https://www.intercambius.com.ar,https://intercambius.com.ar"

# Didit (KYC): workflow en consola Didit, API key y secreto del webhook (API & Webhooks en Didit)
ID_DIDIT=""
API_KEY_DIDIT=""
DIDIT_WEBHOOK_SECRET=""

# Correo (Gmail: usar contraseña de aplicación en SMTP_PASS)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="Intercambius.info@gmail.com"
SMTP_PASS="tu_contraseña_de_aplicación"
SMTP_FROM="Intercambius <Intercambius.info@gmail.com>"
