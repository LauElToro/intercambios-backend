# Base de datos
DATABASE_URL="postgresql://user:pass@localhost:5432/intercambius"

# URL pública del frontend (enlaces en correos, reset password, callback KYC). Sin barra final. No afecta CORS.
FRONTEND_URL="https://intercambius.com.ar"

# Didit (KYC): API key y webhook en consola (API & Webhooks). ID_DIDIT = UUID del workflow.
# Ese workflow en Didit debe incluir SOLO: verificación de ID, liveness pasivo, Face Match 1:1 y análisis de IP
# (sin AML, email/phone verification extra, NFC, etc., salvo que los habiliten a propósito).
ID_DIDIT=""
API_KEY_DIDIT=""
# Firma HMAC de webhooks: en Didit se llama "Webhook Secret Key" (o secret_shared_key vía API). Pegala acá:
DIDIT_WEBHOOK_SECRET=""
# Opcional: mismo valor que arriba si Didit solo te muestra secret_shared_key con otro nombre:
# DIDIT_SECRET_SHARED_KEY=""

# Correo (Gmail: usar contraseña de aplicación en SMTP_PASS)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="Intercambius.info@gmail.com"
SMTP_PASS="tu_contraseña_de_aplicación"
SMTP_FROM="Intercambius <Intercambius.info@gmail.com>"
