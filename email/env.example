# Cuenta que envía (debe coincidir con la que autorizaste en Google)
GMAIL_USER=intercambius.info@gmail.com

# OAuth 2.0 — Google Cloud Console → APIs y servicios → Credenciales → ID de cliente OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Una sola vez: generar con `npm run obtain-token` en esta carpeta (ver README)
GOOGLE_REFRESH_TOKEN=
